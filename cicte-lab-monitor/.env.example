# Copy this file to .env and fill in your values (never commit .env).
# Generate random secrets with: openssl rand -hex 32

# ── Supabase (required) ────────────────────────────────────────────────────────

# Project URL: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co
# Service Role key (server-only, never expose to browser)
# Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=

# ── Server secrets (required in production) ───────────────────────────────────

# HMAC key used to sign auth tokens — must be a long random string
TOKEN_SECRET=

# Shared key the PC agents send in X-Agent-Key header
AGENT_KEY=

# Admin account credentials
ADMIN_USER=admin
ADMIN_PASS=

# Read-only viewer account credentials
VIEWER_USER=viewer
VIEWER_PASS=

# Allowed CORS origin for the frontend (e.g. https://your-domain.com)
CORS_ORIGIN=http://localhost:5173

# ── Frontend (Vite) config ────────────────────────────────────────────────────

# Backend API base URL (leave empty to use Vite dev proxy)
VITE_API_URL=

# Socket.io URL (leave empty to disable real-time)
# Example: http://localhost:3001
VITE_SOCKET_URL=
